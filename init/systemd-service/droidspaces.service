# sudo cp /path/to/compiled/droidspaces /usr/bin/droidspaces
# sudo chmod +x /usr/bin/droidspaces
# sudo cp init/systemd-service/droidspaces.service /etc/systemd/system/
# sudo systemctl daemon-reload
# sudo systemctl enable --now droidspaces

[Unit]
Description=Droidspaces Daemon
After=network.target

[Service]
ExecStart=/usr/bin/droidspaces daemon --foreground
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
